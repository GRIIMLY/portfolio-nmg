# Copia este archivo como .env y completa los valores

# ── Admin credentials ──
# El usuario admin
VITE_ADMIN_USER=admin
# SHA-256 de tu password. Generar en: https://emn178.github.io/online-tools/sha256.html
VITE_ADMIN_HASH=

# ── Supabase ──
# Obtener desde: https://supabase.com → Tu proyecto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
